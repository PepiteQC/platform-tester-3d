{
  "name": "troxt",
  "version": "1.0.0",
  "description": "TroxT - Autonomous Smart Contract Audit & RPA Orchestration Engine",
  "type": "module",
  "engines": {
    "node": ">=20.10.0"
  },
  "main": "./dist/index.js",
  "scripts": {
    "dev": "node --watch -r dotenv/config src/index.js",
    "start": "node --env-file=.env dist/index.js",
    "build": "node build.mjs",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest",
    "lint": "eslint src/**/*.js --cache --fix",
    "format": "prettier --write \"src/**/*.js\""
  },
  "keywords": [
    "solidity",
    "audit",
    "mutation-testing",
    "rpa",
    "foundry",
    "security",
    "web3"
  ],
  "author": "TroxT Team",
  "license": "MIT",
  "dependencies": {
    "async-mutex": "^0.5.0",
    "bullmq": "^5.12.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "pino": "^9.1.0",
    "pino-pretty": "^11.2.0",
    "three": "^0.184.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "eslint": "^9.3.0",
    "prettier": "^3.3.0",
    "vitest": "^2.0.0"
  }
}
