{
  "name": "troxt",
  "version": "1.0.0",
  "description": "TroxT - Autonomous Smart Contract Audit & RPA Orchestration Engine",
  "type": "module",
  "engines": {
    "node": ">=20.10.0"
  },
  "main": "./dist/index.js",
  "scripts": {
    "dev": "node --watch --env-file=.env src/index.js",
    "start": "node --env-file=.env dist/index.js",
    "build": "node build.mjs",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/**/*.js --cache --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "audit:fix": "pnpm audit --fix",
    "deps:check": "pnpm outdated"
  },
  "keywords": [
    "solidity",
    "audit",
    "mutation-testing",
    "rpa",
    "foundry",
    "security",
    "web3"
  ],
  "author": "TroxT Team",
  "license": "MIT",
  "dependencies": {
    "@solidity-parser/parser": "^0.20.2",
    "async-mutex": "^0.5.0",
    "bullmq": "^5.12.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "pino": "^9.1.0",
    "pino-pretty": "^11.2.0",
    "solc": "0.8.28",
    "uuid": "^11.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.3.0",
    "prettier": "^3.3.0",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "msgpackr-extract"
    ]
  }
}