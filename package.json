{
  "name": "platform-tester-3d",
  "version": "2.0.0",
  "type": "module",
  "description": "EtherAudit — Solidity Mutation Testing Platform",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "node --watch server/server.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server/server.mjs",
    "test": "npm run test:client && npm run test:server",
    "test:client": "vitest run --config vitest.client.config.js",
    "test:server": "vitest run --config vitest.server.config.js",
    "test:watch": "vitest --config vitest.client.config.js",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src server --ext .js,.jsx,.mjs"
  },
  "dependencies": {
    "@solidity-parser/parser": "^0.18.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "solc": "^0.8.24",
    "uuid": "^9.0.0",
    "winston": "^3.11.0",
    "ws": "^8.16.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^14.1.2",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^1.2.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "supertest": "^6.3.4",
    "vite": "^5.0.0",
    "vitest": "^1.2.0"
  }
}
